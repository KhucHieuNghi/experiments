{
  "name": "etus-agent",
  "version": "0.1.21",
  "private": false,
  "description": "The self-improving Agentic QA harness with Memory",
  "keywords": [
    "ETUS",
    "ai",
    "ai-agent",
    "ai-testing",
    "agentic-testing",
    "agentic-qa",
    "testing",
    "test-automation",
    "qa-harness",
    "e2e-testing",
    "end-to-end-testing",
    "automation",
    "cli",
    "javascript",
    "typescript",
    "web",
    "mobile",
    "browser-automation",
    "natural-language-testing",
    "self-improving",
    "playwright",
    "appium",
    "webdriverio",
    "qa",
    "quality-assurance",
    "self-healing-tests",
    "mcp",
    "fair-source",
    "fsl"
  ],
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "https://www.onpoint.vn",
  "bugs": {
    "url": "https://www.onpoint.vn"
  },
  "repository": {
    "type": "git",
    "url": "https://www.onpoint.vn",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=24"
  },
  "type": "module",
  "bin": {
    "etus-agent": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE.md",
    "NOTICE.md"
  ],
  "scripts": {
    "build": "tsup",
    "copy:skills": "node scripts/copy-skills.mjs",
    "dev": "tsup --watch",
    "prepack": "pnpm run copy:skills",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@inquirer/checkbox": "5.1.4",
    "@inquirer/confirm": "6.0.12",
    "@inquirer/input": "5.0.12",
    "@inquirer/password": "5.0.12",
    "@inquirer/select": "5.1.4",
    "@etus/agent-android": "workspace:*",
    "@etus/agent-core": "workspace:*",
    "@etus/agent-dashboard": "workspace:*",
    "@etus/agent-dashboard-ui": "workspace:*",
    "@etus/agent-ids": "workspace:*",
    "@etus/agent-ios": "workspace:*",
    "@etus/agent-mcp": "workspace:*",
    "@etus/agent-web": "workspace:*",
    "ai": "6.0.174",
    "commander": "14.0.3",
    "glob": "13.0.6",
    "picocolors": "1.1.1",
    "playwright-core": "1.59.1",
    "yaml": "2.8.4",
    "zod": "4.4.2"
  },
  "devDependencies": {
    "@types/node": "~24.12.2",
    "tsup": "~8.5.1",
    "typescript": "~6.0.3",
    "vitest": "~4.1.5"
  }
}
