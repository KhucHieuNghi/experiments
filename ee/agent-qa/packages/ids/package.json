{
  "name": "@etus/agent-qa-ids",
  "version": "0.1.21",
  "private": false,
  "description": "Canonical ID helpers for ETUS tests, suites, hooks, and artifacts.",
  "keywords": [
    "ETUS",
    "testing",
    "ids",
    "validation"
  ],
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "https://www.onpoint.vn",
  "bugs": {
    "url": "https://www.onpoint.vn"
  },
  "repository": {
    "type": "git",
    "url": "https://www.onpoint.vn",
    "directory": "packages/ids"
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE.md",
    "NOTICE.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "id-agent": "1.0.3"
  },
  "devDependencies": {
    "@types/node": "~24.12.2",
    "tsup": "~8.5.1",
    "typescript": "~6.0.3",
    "vitest": "~4.1.5"
  }
}
