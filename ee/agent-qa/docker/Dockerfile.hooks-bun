FROM oven/bun:1-slim

LABEL org.opencontainers.image.title="ETUS Hook Runner Bun" \
      org.opencontainers.image.description="Bun hook sandbox runtime for ETUS" \
      org.opencontainers.image.licenses="SEE LICENSE IN LICENSE.md" \
      org.opencontainers.image.vendor="ETUS"

COPY LICENSE.md /licenses/etus-agent/LICENSE.md

RUN groupadd -r hookuser && useradd -r -g hookuser -d /workspace -s /bin/sh hookuser

WORKDIR /workspace

USER hookuser
